<UserControl x:Class="eodh.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:converters="clr-namespace:eodh.Converters"
             mc:Ignorable="d">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <Style x:Key="EodhPrimaryButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Background" Value="#4C72BA" />
            <Setter Property="BorderBrush" Value="#4C72BA" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="8,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonChrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="#3F64AB" />
                                <Setter TargetName="ButtonChrome"
                                        Property="BorderBrush"
                                        Value="#3F64AB" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="Background"
                                        Value="#355898" />
                                <Setter TargetName="ButtonChrome"
                                        Property="BorderBrush"
                                        Value="#355898" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="ButtonChrome"
                                        Property="BorderBrush"
                                        Value="#24395D" />
                                <Setter TargetName="ButtonChrome"
                                        Property="BorderThickness"
                                        Value="2" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonChrome"
                                        Property="Opacity"
                                        Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16" ClipToBounds="True">
        <!-- A restrained orbital motif echoes the EO DataHub identity while
             leaving the native ArcGIS surface and controls intact. -->
        <Viewbox Stretch="UniformToFill"
                 IsHitTestVisible="False"
                 Opacity="0.5">
            <Canvas Width="520" Height="620">
                <Path Data="M -80,210 C 80,10 310,18 610,170"
                      Stroke="#4C72BA"
                      StrokeThickness="1"
                      Opacity="0.24" />
                <Path Data="M -60,58 C 130,112 302,240 600,274"
                      Stroke="#BDCFEB"
                      StrokeThickness="1"
                      Opacity="0.32" />
                <Ellipse Canvas.Left="63"
                         Canvas.Top="121"
                         Width="7"
                         Height="7"
                         Fill="#4C72BA"
                         Opacity="0.24" />
                <Ellipse Canvas.Left="340"
                         Canvas.Top="69"
                         Width="10"
                         Height="10"
                         Fill="#4C72BA"
                         Opacity="0.18" />
            </Canvas>
        </Viewbox>

        <StackPanel VerticalAlignment="Center"
                    MaxWidth="350"
                    Margin="0,12">
            <Image Source="/eodh;component/Images/Brand/eodh-logo-colour.png"
                   Width="218"
                   Height="81"
                   Stretch="Uniform"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,14"
                   SnapsToDevicePixels="True" />

            <TextBlock Text="Connect your workspace"
                       FontSize="20"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,7" />

            <TextBlock Text="Sign in with your EODH workspace credentials to search and access satellite imagery."
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,24"
                       Opacity="0.72" />

            <!-- Workspace Name -->
            <TextBlock Text="Workspace name" Margin="0,0,0,4" />
            <TextBox Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,12" />

            <!-- Workspace API key -->
            <TextBlock Text="Workspace API key" Margin="0,0,0,4" />
            <PasswordBox x:Name="ApiTokenBox"
                         Margin="0,0,0,4" />
            <TextBlock Text="Paste the API Key, not the Token ID."
                       FontSize="11" Opacity="0.7" Margin="0,0,0,5" />
            <StackPanel Margin="0,0,0,16">
                <TextBlock FontSize="11" Margin="0,0,0,2">
                    <Hyperlink NavigateUri="https://docs.eodatahub.org.uk/Getting-Started/workspaces/workspace-credentials/"
                               RequestNavigate="OpenLink_RequestNavigate"
                               ToolTip="Open the EODH workspace documentation">
                        <Run Text="&#xE8F1;"
                             FontFamily="Segoe MDL2 Assets"
                             FontSize="12"
                             BaselineAlignment="Center" />
                        <Run Text="  EODH documentation" />
                    </Hyperlink>
                </TextBlock>
                <TextBlock FontSize="11">
                    <Hyperlink NavigateUri="{Binding WorkspaceCredentialsUri}"
                               RequestNavigate="OpenLink_RequestNavigate"
                               ToolTip="Open credentials for this EODH workspace">
                        <Run Text="&#xE8D7;"
                             FontFamily="Segoe MDL2 Assets"
                             FontSize="12"
                             BaselineAlignment="Center" />
                        <Run Text="  Open EODH workspace credentials" />
                    </Hyperlink>
                </TextBlock>
            </StackPanel>

            <!-- Error message -->
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="Red"
                       TextWrapping="Wrap"
                       Visibility="{Binding HasError, Converter={StaticResource BoolToVis}}"
                       Margin="0,0,0,12" />

            <!-- Login button -->
            <Button Content="Connect"
                    Command="{Binding LoginCommand}"
                    Style="{StaticResource EodhPrimaryButtonStyle}"
                    HorizontalAlignment="Stretch"
                    IsDefault="True" />

            <!-- Loading indicator -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                         Foreground="#4C72BA"
                         Margin="0,8,0,0"
                         Height="3" />
        </StackPanel>
    </Grid>
</UserControl>
