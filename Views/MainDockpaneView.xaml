<UserControl x:Class="eodh.Views.MainDockpaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:eodh.Views"
             xmlns:converters="clr-namespace:eodh.Converters"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="600">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <Grid>
        <!-- Login panel (shown when not logged in) -->
        <views:LoginView DataContext="{Binding LoginVM}"
                         Visibility="{Binding DataContext.IsLoggedIn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}" />

        <!-- Main content (shown when logged in) -->
        <DockPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">

            <!-- User info header -->
            <Grid DockPanel.Dock="Top" Margin="8,6,8,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock VerticalAlignment="Center" Opacity="0.7" FontSize="11">
                    <Run Text="Signed in as " />
                    <Run Text="{Binding LoggedInUsername}" FontWeight="SemiBold" />
                    <Run Text=" (" /><Run Text="{Binding LoggedInEnvironment}" /><Run Text=")" />
                </TextBlock>
                <Button Content="Sign Out"
                        Command="{Binding LogoutCommand}"
                        Grid.Column="1"
                        Padding="8,2" FontSize="11" />
            </Grid>

            <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <TabItem Header="Search">
                <views:SearchView DataContext="{Binding SearchVM}" />
            </TabItem>

            <TabItem Header="Results">
                <DockPanel>
                    <views:TimelineView DataContext="{Binding TimelineVM}"
                                        DockPanel.Dock="Top"
                                        Height="80" />
                    <views:ResultsView DataContext="{Binding ResultsVM}" />
                </DockPanel>
            </TabItem>

            <TabItem Header="Workspace">
                <views:WorkspaceView DataContext="{Binding WorkspaceVM}" />
            </TabItem>

            <TabItem Header="Workflows">
                <views:WorkflowsView DataContext="{Binding WorkflowsVM}" />
            </TabItem>

        </TabControl>
        </DockPanel>
    </Grid>
</UserControl>
