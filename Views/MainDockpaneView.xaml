<UserControl x:Class="eodh.Views.MainDockpaneView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:views="clr-namespace:eodh.Views"
             xmlns:converters="clr-namespace:eodh.Converters"
             mc:Ignorable="d"
             d:DesignWidth="400" d:DesignHeight="600">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <Style x:Key="BrandHeaderActionButtonStyle"
               TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="#4C72BA" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#184C72BA" />
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="#304C72BA" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- Login panel (shown when not logged in) -->
        <views:LoginView DataContext="{Binding LoginVM}"
                         Visibility="{Binding DataContext.IsLoggedIn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}" />

        <!-- Main content (shown when logged in) -->
        <DockPanel Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVis}}">

            <!-- Compact EO DataHub header. The native surface and typography are
                 preserved; brand identity comes from the mark and accent colour. -->
            <Border DockPanel.Dock="Top"
                    Background="#104C72BA"
                    BorderBrush="#4C72BA"
                    BorderThickness="0,0,0,2"
                    Padding="9,7,7,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Image Grid.RowSpan="2"
                           Source="/eodh;component/Images/Brand/eodh-mark.png"
                           Width="35"
                           Height="35"
                           Stretch="Uniform"
                           VerticalAlignment="Center"
                           Margin="0,0,9,0" />

                    <TextBlock Grid.Column="1"
                               Text="{Binding LoggedInUsername, Mode=OneWay}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Bottom"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding LoggedInUsername, Mode=OneWay}" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               FontSize="10"
                               Opacity="0.7"
                               VerticalAlignment="Top"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding LoggedInEnvironment, Mode=OneWay}">
                        <Run Text="•  " />
                        <Run Text="{Binding LoggedInEnvironment, Mode=OneWay}" />
                    </TextBlock>

                    <StackPanel Grid.RowSpan="2"
                                Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0">
                        <Button Content="Switch"
                                ToolTip="Switch workspace"
                                Command="{Binding SwitchWorkspaceCommand}"
                                Style="{StaticResource BrandHeaderActionButtonStyle}" />
                        <Border Width="1"
                                Height="18"
                                Background="#384C72BA"
                                Margin="2,0"
                                VerticalAlignment="Center" />
                        <Button Content="Log out"
                                Command="{Binding LogoutCommand}"
                                Style="{StaticResource BrandHeaderActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Dockpane-wide asset activity. Bind through the main view model so
                 the data contexts inherited by the tab contents remain unchanged. -->
            <Border DockPanel.Dock="Bottom"
                    Height="56"
                    Background="#1C808080"
                    BorderBrush="#66808080"
                    BorderThickness="0,1,0,0"
                    Padding="8,5"
                    SnapsToDevicePixels="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Border Background="#24808080"
                            CornerRadius="2"
                            Padding="5,1"
                            Margin="0,0,7,0"
                            VerticalAlignment="Center">
                        <TextBlock Text="STATUS"
                                   FontSize="8"
                                   FontWeight="SemiBold"
                                   Opacity="0.75" />
                    </Border>
                    <TextBlock Grid.Column="1"
                               Text="{Binding AssetLoadStatus.StatusText, Mode=OneWay}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding AssetLoadStatus.StatusText, Mode=OneWay}" />
                    <TextBlock Grid.Column="2"
                               Text="{Binding AssetLoadStatus.ProgressText, Mode=OneWay}"
                               FontSize="10"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0" />
                    <TextBlock Grid.Row="1"
                               Grid.Column="1"
                               Grid.ColumnSpan="2"
                               Text="{Binding AssetLoadStatus.DetailText, Mode=OneWay}"
                               FontSize="9"
                               Opacity="0.7"
                               TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding AssetLoadStatus.DetailText, Mode=OneWay}" />
                    <ProgressBar Grid.Row="2"
                                 Grid.ColumnSpan="3"
                                 Minimum="0"
                                 Maximum="100"
                                 Value="{Binding AssetLoadStatus.ProgressValue, Mode=OneWay}"
                                 IsIndeterminate="{Binding AssetLoadStatus.HasNonReadyStatus, Mode=OneWay}"
                                 Visibility="{Binding AssetLoadStatus.HasNonReadyStatus, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                                 Height="3"
                                 Margin="0,4,0,0" />
                </Grid>
            </Border>

            <TabControl SelectedIndex="{Binding SelectedTabIndex}">

            <TabItem Header="Search">
                <views:SearchView DataContext="{Binding SearchVM}" />
            </TabItem>

            <TabItem Header="Results">
                <DockPanel>
                    <views:TimelineView DataContext="{Binding TimelineVM}"
                                        DockPanel.Dock="Top"
                                        Height="92" />
                    <StackPanel DockPanel.Dock="Top"
                                Orientation="Horizontal"
                                Margin="8,5,8,2">
                        <CheckBox Content="Show footprints"
                                  IsChecked="{Binding ResultsVM.ShowFootprints}" />
                        <CheckBox Content="Show AOI"
                                  IsChecked="{Binding SearchVM.ShowAoi}"
                                  Margin="16,0,0,0" />
                    </StackPanel>
                    <views:ResultsView DataContext="{Binding ResultsVM}" />
                </DockPanel>
            </TabItem>

            <TabItem Header="Workspace">
                <views:WorkspaceView DataContext="{Binding WorkspaceVM}" />
            </TabItem>

        </TabControl>
        </DockPanel>
    </Grid>
</UserControl>
